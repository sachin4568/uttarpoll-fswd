{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/index.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/(assets|public|scripts|css|js)/(.*)",
      "dest": "/$1/$2",
      "continue": true
    },
    {
      "src": "/payments.js",
      "dest": "/payments.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
